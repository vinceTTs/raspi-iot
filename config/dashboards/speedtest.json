{
  "id": null,
  "uid": "speedtest",
  "title": "Internet Speed",
  "tags": ["network", "speedtest"],
  "timezone": "",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Download (Mbps)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "Mbps" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"network\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"internet_speed\" and r._field == \"download_bps\") |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000000.0 }))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upload (Mbps)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "Mbps" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"network\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"internet_speed\" and r._field == \"upload_bps\") |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000000.0 }))",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"network\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"internet_speed\" and r._field == \"latency_ms\")",
          "refId": "C"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Latest Download",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Mbps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }, "orientation": "auto" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"network\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"internet_speed\" and r._field == \"download_bps\") |> last() |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000000.0 }))",
          "refId": "D"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Latest Upload",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Mbps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }, "orientation": "auto" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"network\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"internet_speed\" and r._field == \"upload_bps\") |> last() |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000000.0 }))",
          "refId": "E"
        }
      ]
    }
  ]
}
